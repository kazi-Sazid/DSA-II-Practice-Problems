//Find the largest and smallest element of a given array
void findLargestAndSmallest(int arr[], int size, int index, int *max, int *min) {
    if (index == size) {
        return;
    }

    if (arr[index] > *max) {
        *max = arr[index];
    }

    if (arr[index] < *min) {
        *min = arr[index];
    }

    findLargestAndSmallest(arr, size, index + 1, max, min);
}

int main()
{
    int arr[] = {2, 3, 5, 7, 11};
    int size = sizeof(arr)/sizeof(int);
    int max = arr[0];
    int min = arr[0];
    findLargestAndSmallest(arr, size, 0, &max, &min);
    printf("Max: %d\nMin: %d", max, min);
    return 0;
}


